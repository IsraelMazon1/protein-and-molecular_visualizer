MONGODB_DB_NAME=molecularai
MONGODB_COLLECTION=structures
MONGODB_SUGGESTIONS_COLLECTION=search_suggestions
MONGODB_VECTOR_INDEX=embedding_vector_index
VULTR_HOST=your-vultr-host
VULTR_USER=root
VULTR_APP_DIR=/opt/molecularai
BACKEND_PORT=8000
VITE_API_BASE_URL=http://localhost:8000
